{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "flutter run windows",
			"type": "shell",
			"command": "flutter",
			"args": [
				"run",
				"-d",
				"windows",
				"--dart-define=BACKEND_URL=http://localhost:3000"
			],
			"isBackground": true,
			"problemMatcher": [
				"$flutter-watch"
			],
			"group": "build"
		},
		{
			"label": "flutter run chrome",
			"type": "shell",
			"command": "flutter",
			"args": [
				"run",
				"-d",
				"chrome",
				"--dart-define=BACKEND_URL=http://localhost:3000"
			],
			"isBackground": true,
			"problemMatcher": [
				"$flutter-watch"
			],
			"group": "build"
		}
	]
}